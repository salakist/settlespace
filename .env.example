# Local environment overrides for quality gate scripts.
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real tokens.
#
# Optional SonarScanner parity step (run-full-checks only).
# Set SONAR_SCANNER_ENABLED=1 to enable the step.
# Obtain a token from https://sonarcloud.io/account/security
SONAR_SCANNER_ENABLED=1
SONAR_TOKEN=your-sonarcloud-token-here

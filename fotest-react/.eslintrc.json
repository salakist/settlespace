{
  "extends": [
    "react-app",
    "react-app/jest",
    "plugin:sonarjs/recommended"
  ],
  "plugins": [
    "sonarjs"
  ],
  "rules": {
    "sonarjs/cognitive-complexity": ["warn", 15],
    "sonarjs/no-duplicate-string": ["warn", { "minimumRepetitions": 3 }],
    "sonarjs/no-identical-functions": "error"
  }
}

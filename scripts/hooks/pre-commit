#!/bin/sh
# scripts/hooks/pre-commit
#
# Git pre-commit hook.
# Blocks commits when the changed-code quality gates fail.

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if [ ! -f "scripts/run-checks.sh" ]; then
  echo "ERROR: scripts/run-checks.sh not found. Is this the fo-test repo root?"
  exit 1
fi

sh scripts/run-checks.sh

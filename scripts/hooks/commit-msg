#!/bin/sh
# scripts/hooks/commit-msg
#
# Git commit-msg hook launcher.
# Ensures agent-authored commits use the dedicated repo identity, include
# the required agent attribution trailer, and follow Conventional Commits.

COMMIT_MSG_FILE="$1"

if [ -z "$COMMIT_MSG_FILE" ] || [ ! -f "$COMMIT_MSG_FILE" ]; then
  echo "ERROR: commit-msg hook did not receive a valid commit message file."
  exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "$REPO_ROOT" ]; then
  echo "ERROR: Unable to determine the settlespace repository root."
  exit 1
fi

cd "$REPO_ROOT" || exit 1

AGENT_NAME="$(git config --get settlespace.agentName 2>/dev/null)"
AGENT_EMAIL="$(git config --get settlespace.agentEmail 2>/dev/null)"
AGENT_TRAILER_VALUE="$(git config --get settlespace.agentTrailer 2>/dev/null)"
REQUIRE_REVIEWED_BY="$(git config --bool --get settlespace.requireReviewedBy 2>/dev/null)"
AUTHOR_NAME="$(git config --get user.name 2>/dev/null)"
AUTHOR_EMAIL="$(git config --get user.email 2>/dev/null)"
COMMITLINT_PREFIX="$REPO_ROOT/scripts"
COMMITLINT_CONFIG="$COMMITLINT_PREFIX/commitlint.config.cjs"

if [ -z "$AGENT_NAME" ]; then
  AGENT_NAME="settlespace-agent"
fi

if [ -z "$AGENT_EMAIL" ]; then
  AGENT_EMAIL="settlespace-agent@local"
fi

if [ -z "$AGENT_TRAILER_VALUE" ]; then
  AGENT_TRAILER_VALUE="GitHub Copilot"
fi

if [ -z "$REQUIRE_REVIEWED_BY" ]; then
  REQUIRE_REVIEWED_BY="false"
fi

print_conventional_commit_examples() {
  echo "Expected format: <type>(<optional scope>)!: <description>"
  echo "Examples:"
  echo "  feat(auth): add token refresh handling"
  echo "  fix(persons): prevent duplicate email save"
  echo "  chore(scripts): enforce conventional commits"
  echo "  feat(api)!: remove legacy status endpoint"
}

validate_conventional_commit() {
  if ! command -v npx >/dev/null 2>&1; then
    echo "ERROR: Conventional Commit validation requires Node.js/npm (npx) on PATH."
    echo "Run 'cd $COMMITLINT_PREFIX && npm install' after installing Node.js."
    return 1
  fi

  if [ ! -f "$COMMITLINT_CONFIG" ]; then
    echo "ERROR: Conventional Commit validation config was not found at '$COMMITLINT_CONFIG'."
    return 1
  fi

  if [ ! -d "$COMMITLINT_PREFIX/node_modules/@commitlint" ]; then
    echo "ERROR: Conventional Commit validation dependencies are not installed for this repository."
    echo "Run 'cd $COMMITLINT_PREFIX && npm install'."
    return 1
  fi

  if ! npx --no-install --prefix "$COMMITLINT_PREFIX" commitlint --config "$COMMITLINT_CONFIG" --edit "$COMMIT_MSG_FILE"; then
    echo ""
    print_conventional_commit_examples
    return 1
  fi

  return 0
}

EXPECTED_AGENT_LINE="Agent: $AGENT_TRAILER_VALUE"
IS_AGENT_AUTHOR=0
HAS_AGENT_TRAILER=0
HAS_EXPECTED_AGENT_TRAILER=0
HAS_REVIEWED_BY=0

if [ "$AUTHOR_NAME" = "$AGENT_NAME" ] || [ "$AUTHOR_EMAIL" = "$AGENT_EMAIL" ]; then
  IS_AGENT_AUTHOR=1
fi

if grep -Fqi "Agent:" "$COMMIT_MSG_FILE"; then
  HAS_AGENT_TRAILER=1
fi

if grep -Fqi "$EXPECTED_AGENT_LINE" "$COMMIT_MSG_FILE"; then
  HAS_EXPECTED_AGENT_TRAILER=1
fi

if grep -Eqi '^Reviewed-by:[[:space:]].+' "$COMMIT_MSG_FILE"; then
  HAS_REVIEWED_BY=1
fi

if [ "$IS_AGENT_AUTHOR" -eq 1 ] && [ "$HAS_EXPECTED_AGENT_TRAILER" -ne 1 ]; then
  echo "ERROR: Agent-authored commits in settlespace must include the trailer '$EXPECTED_AGENT_LINE'."
  echo ""
  echo "Current identity:"
  echo "  user.name  = ${AUTHOR_NAME:-<unset>}"
  echo "  user.email = ${AUTHOR_EMAIL:-<unset>}"
  echo ""
  echo "Example:"
  echo "  chore(scope): describe the change"
  echo ""
  echo "  $EXPECTED_AGENT_LINE"
  if [ "$REQUIRE_REVIEWED_BY" = "true" ]; then
    echo "  Reviewed-by: <human name>"
  fi
  exit 1
fi

if [ "$IS_AGENT_AUTHOR" -ne 1 ] && [ "$HAS_AGENT_TRAILER" -eq 1 ]; then
  echo "ERROR: Commits that include an 'Agent:' trailer must use the configured agent identity."
  echo ""
  echo "Configured agent identity:"
  echo "  user.name  = $AGENT_NAME"
  echo "  user.email = $AGENT_EMAIL"
  exit 1
fi

if [ "$IS_AGENT_AUTHOR" -eq 1 ] && [ "$REQUIRE_REVIEWED_BY" = "true" ] && [ "$HAS_REVIEWED_BY" -ne 1 ]; then
  echo "ERROR: Agent-authored commits currently require a 'Reviewed-by:' trailer as well."
  exit 1
fi

if ! validate_conventional_commit; then
  exit 1
fi

exit 0

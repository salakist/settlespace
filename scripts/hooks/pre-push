#!/bin/sh
# scripts/hooks/pre-push
#
# Git pre-push hook.
# Calls the changed-code checks used to block pushes.
#
# Install this hook by running (once per clone):
#   sh scripts/setup-hooks.sh      (Linux / macOS / Git Bash)
#   .\scripts\setup-hooks.ps1      (Windows PowerShell)
#
# DO NOT bypass this hook with --no-verify.

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if [ ! -f "scripts/run-checks.sh" ]; then
  echo "ERROR: scripts/run-checks.sh not found. Is this the fo-test repo root?"
  exit 1
fi

ZERO_SHA="0000000000000000000000000000000000000000"
set --

while read -r local_ref local_sha remote_ref remote_sha; do
  # Deletion push: no new content to analyze for this ref.
  if [ "$local_sha" = "$ZERO_SHA" ]; then
    continue
  fi

  if [ "$remote_sha" = "$ZERO_SHA" ]; then
    set -- "$@" "--push-new-sha" "$local_sha"
  else
    set -- "$@" "--push-range" "$remote_sha..$local_sha"
  fi
done

sh scripts/run-checks.sh "$@"

# FoTestApi.Application local ignore rules.
# Shared artifacts (bin/obj/.vs/.vscode/*.user/*.suo/node_modules/artifacts/logs) are defined in repository root .gitignore.

# Configuration and package artifacts for standalone project use
*.rsuser
*.userosscache
*.sln.docstates
*.nupkg
*.snupkg
*.nuget
packages/

# Platform/build output folders not covered explicitly by root rules
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
[Dd]ebugPS/
[Rr]eleasePS/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/

# Tooling and diagnostics artifacts
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
.JustCode
_TeamCity*
*.dotCover
.axoCover/*
!.axoCover/settings.json
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*
*.coverage
*.coveragexml
coverage*.json

# Generated scaffolding and miscellaneous outputs
ScaffoldingReadMe.txt
StyleCopReport.xml
BenchmarkDotNet.Artifacts/
TestResults/
nunit-*.xml
TestResult.xml
*.VisualState.xml
*.stackdump
mono_crash.*
*.sln.iml
